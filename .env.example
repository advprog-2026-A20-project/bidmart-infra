# =========================
# BidMart Infra Environment
# =========================

# Postgres
POSTGRES_PORT=5432
POSTGRES_DB=bidmart
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Gateway / Frontend
GATEWAY_PORT=8080
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8080/api
JWT_SECRET=local-dev-secret-please-change-32-chars
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Services (host ports)
AUTH_SERVICE_PORT=8081
LISTING_QUERY_SERVICE_PORT=8082
AUCTION_QUERY_SERVICE_PORT=8083
BIDDING_COMMAND_SERVICE_PORT=8084
WALLET_SERVICE_PORT=8085
NOTIFICATION_SERVICE_PORT=8086
ENABLE_NOTIFICATION=false
